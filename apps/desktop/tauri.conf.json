{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RabbitHole",
  "version": "0.105.0",
  "identifier": "com.mirrorward.rabbithole",
  "build": {
    "beforeDevCommand": {
      "script": "trunk serve --address 127.0.0.1 --port 1420",
      "cwd": "../../crates/ui-web"
    },
    "beforeBuildCommand": {
      "script": "trunk build",
      "cwd": "../../crates/ui-web"
    },
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../crates/ui-web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "RabbitHole",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws: wss: https:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; media-src 'self' http: https: blob:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
